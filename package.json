{
  "name": "kontrola-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint .",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "api:generate": "openapi-typescript-codegen --input ${OPENAPI_SPEC_URL:-https://api.kontrola.com.mx/swagger/v1/swagger.json} --output src/api/generated --client axios --useOptions --useUnionTypes"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "pinia": "^2.3.1",
    "primevue": "^4.3.3",
    "@primevue/themes": "^4.3.3",
    "primeicons": "^7.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@tsconfig/node22": "^22.0.1",
    "@types/node": "^22.13.14",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "^9.32.0",
    "@eslint/js": "^9.22.0",
    "typescript-eslint": "^8.26.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.4",
    "tailwindcss-primeui": "^0.5.1",
    "typescript": "~5.8.0",
    "vite": "^6.2.4",
    "vitest": "^3.1.1",
    "vue-tsc": "^2.2.8",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.0.0",
    "msw": "^2.7.3",
    "openapi-typescript-codegen": "^0.29.0"
  }
}
